# Rust build output
/target

# External / large game assets (EQ .s3d-derived data, glTF models) — sourced separately
/assets

# Runtime logs
*.log

# Per-character UI layout state written by the app at runtime
ui_layout_*.json

# Per-character login configs with credentials — live in ~/.config/eqoxide/
config-*.yaml

# EQ-Atlas / fan zone maps and other third-party game-derived images
Zone_*.jpg
Zone_*.png

# Claude Code workspace (agents, skills, settings, local state) — not published
.claude/

# Superpowers plans/specs — developer-local, not published
docs/superpowers/

# EQ technical knowledgebase — moved to the private ~/git/eq_kb repo (2026-07-17).
# Holds raw native-client / local-infra ground-truth citations; must never be
# re-committed to this public repo. Write new KB notes to ~/git/eq_kb instead.
docs/eq-technical-knowledgebase/

# Tools build output
tools/output/
tools/target/

# Local config / scripts
.opencode/
opencode.json
--out
